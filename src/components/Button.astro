---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'button'> {
	// Additional custom props can be added here
	link?: URL | string;
	theme?: string;
}

const { link = ":", theme="white", type } = Astro.props;
---

<style>
	.button {
		display: block;
		text-align: center;
		border-radius: 5px;
		border: none;
		padding: 10px;
		margin-top: 50px;
		text-transform: uppercase;
		font-weight: bold;
		max-width: 250px;
		width: 100%;
		box-shadow: var(--shadow-elevation-medium);
		font-weight: 900;
		cursor: pointer;
	}

	.white {
		color: var(--ark-blue);
		background-color: white;
		border: 3px solid white;
	}

	.blue {
		color: white;
		background-color: var(--ark-blue);
		border: 3px solid var(--ark-blue);
	}
</style>


{link !== ":" ?  (
	<a class={`button ${theme}`} href={link} >
		<slot />
	</a>
) : (
	<button {type} class={`button ${theme}`}>
		<slot />
	</button>
)}