---
interface Props {
	// Additional custom props can be added here
	link?: URL;
	theme?: string;
	children?: any
}

const { link = ":", theme="white", children } = Astro.props;
---

<style>
	.button {
		border-radius: 5px;
		border: none;
		padding: 10px;
		margin-top: 50px;
		text-transform: uppercase;
		font-weight: bold;
		max-width: 250px;
		width: 100%;
		box-shadow: var(--shadow-elevation-medium);
		font-weight: 900;
		cursor: pointer;
	}

	.white {
		color: var(--ark-blue);
		background-color: white;
		border: 3px solid white;
	}

	.blue {
		color: white;
		background-color: var(--ark-blue);
		border: 3px solid var(--ark-blue);
	}
</style>


{link !== ":" ?  (
	<a class={`button ${theme}`} href={link} >
		{children}
	</a>
) : (
	<button class={`button ${theme}`}>
		{children}
	</button>
)}