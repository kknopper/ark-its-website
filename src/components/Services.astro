---
import Section from './Section.astro';
import ServiceItem from "./ServiceItem.astro";

interface Service {
		name: string,
		title: string,
		copy: string
}

type Services = Service[];

const { services } = Astro.props as { services: Services };;
---
<style>
	:global(.section-services) {
		background-color: white;
		container-type: inline-size;
	}

	.headline {
		text-align: center;
		font-size: 40px;
		margin-bottom: 50px;
		color: var(--ark-blue);
		text-transform: uppercase;
	}

	.service-grid {
		--column-num: 3;
		--row-num: 2;
		--fit-content: 480px;
		--gap: 35px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(var(--column-num), fit-content(var(--fit-content)));
		grid-template-rows: repeat(var(--row-num), 1fr);
		grid-gap: var(--gap);
		justify-content: center;

		@container (max-width: 1700px) {
			--column-num: 2;
			--row-num: 3;
		}

		@container (max-width: 735px) {
			--column-num: 1;
			--row-num: 6;
			--fit-content: 1fr;
			--gap: 15px;
		}
	}

</style>

<Section id="services" className="full-width">
	<h2 class="headline">Services</h2>
	<div class="service-grid">
		{services.map((block, i) => (
			<ServiceItem key={i}  name={block.name} title={block.title} copy={block.copy} />
		))}
	</div>
</Section>