---
import { Image } from 'astro:assets';
import arkImage from "../assets/ark.png";
import Button from './Button.astro';
import Section from './Section.astro'
---

<style>
	:global(.section-hero) {
		background-color: var(--ark-blue);
		position: relative;
		container-type: inline-size;
	}

	.headline {
		font-weight: 900;
		font-size: 5em;

		@container (max-width: 1050px) {
			font-size: 3.75em;
		}

		@container (max-width: 750px) {
			font-size: 4.5em;
		}

		@container (max-width: 650px) {
			font-size: 2.4em;
		}
	}

	.intro {
		max-width: 60%;
		font-size: 1em;
		font-weight: 500;

		@container (max-width: 850px) {
			max-width: 435px;
		}

		@container (max-width: 600px) {
			max-width: 100%;
		}
	}

	.intro + .intro {
		margin-top: 20px;
	}

	.ark {
		position: absolute;
		bottom: 0;
		right: 0;
		height: auto;

		@container (max-width: 800px) {
			margin-bottom: -70px;
			margin-left: auto;
			margin-right: -6%;
			margin-top: 30px;
			position: static;
		}
	}
</style>

<Section id="hero">
	<h1 class="headline">Your IT Sanctuary</h1>
	<p class="intro">ARK is a Managed Service Provider, ready to bring your business to the next level. We provide Networking, VOIP, Helpdesk, Cybersecurity and more.</p>
	<p class="intro">Stop drowning in IT bottlenecks, and board with ARK.</p>
	<Button link="#contact">Board the Ark</Button>
	<Image src={arkImage} alt='Image of the Ark, your IT Sanctuary' width={315} height={368} class="ark" />
</Section>