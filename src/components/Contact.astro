---
import Section from './Section.astro';
import Waves from "./Waves.astro";
import { Fragment } from "react";
import Button from "./Button.astro";
---

<style>
	:global(.section-contact) {
		background-color: var(--ark-blue);
	}

	.headline {
		text-align: center;
		font-size: 40px;
		margin-bottom: 50px;
		color: white;
		text-transform: uppercase;
	}

	.form {
		background: white;
		border-radius: 15px;
		padding: 100px;
		display: grid;
		grid-template-rows: repeat(5, auto);
		grid-gap: 15px;

		@container (width < 800px) {
			padding: 50px;
		}
	}

	.label {
		font-size: 1em;
		text-transform: uppercase;
		font-weight: 900;
		color: var(--ark-blue);
	}

	.input {
		display: block;
		border-radius: 5px;
		border: 3px solid var(--ark-blue);
		color: var(--ark-blue);
		background-color: white;
		height: 50px;
		width: 100%;
	}

	.textarea {
		display: block;
		border-radius: 5px;
		border: 3px solid var(--ark-blue);
		color: var(--ark-blue);
		width: 100%;
		background-color: white;
	}

	.button {
		width: 100%;
		max-width: none;
	}

</style>

<Waves />
<Section id="contact">
	<h2 class="headline">Contact</h2>
	<form name="contact" action="https://api.web3forms.com/submit" method="POST" data-netlify="true" class="form">
		<input type="hidden" name="form-name" value="contact" />
		<input type="hidden" name="access_key" value="7871556e-f25a-4c86-a67a-d6a517ac148b">
		<p>
			<label class="label" html-for="name">Name: <input class="input" type="text" name="name" required/></label>
		</p>
		<p>
			<label class="label" html-for="email">Email: <input class="input" type="email" name="email" required/></label>
		</p>
		<p>
			<label class="label" html-for="company">Company: <input class="input" type="text" name="company" required /></label>
		</p>
		<p>
			<label class="label" html-for="message">Message: <textarea class="textarea" name="message" required></textarea></label>
		</p>
		<p>
			<Button type="submit" theme="blue" class="button">Submit</Button>
		</p>
	</form>
</Section>